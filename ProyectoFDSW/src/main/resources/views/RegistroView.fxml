<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0"
      style="-fx-background-color: #ffffff; -fx-padding: 0px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-font-family: 'Segoe UI', sans-serif;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <!-- TabPane: Iniciar Sesión | Crear Cuenta -->
    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
             style="-fx-tab-min-width: 180px; -fx-font-size: 14px;">

        <!-- ═══════════════════════ TAB LOGIN ═══════════════════════ -->
        <Tab text="🔑  Iniciar Sesión" fx:id="tabLogin">
            <VBox alignment="CENTER" spacing="15" style="-fx-padding: 25px 30px 20px 30px;">

                <Label text="Bienvenido de nuevo" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Label text="Ingresa tus credenciales para continuar." style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>

                <!-- Email login -->
                <VBox spacing="5">
                    <Label text="Correo Electrónico:" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEmailLogin" promptText="ejemplo@correo.com"
                               style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
                    <!-- Indicador de si ya está registrado -->
                    <Label fx:id="lblEstadoRegistro" text=""
                           style="-fx-font-size: 12px; -fx-font-weight: bold;"
                           visible="false" managed="false"/>
                </VBox>

                <!-- Contraseña login -->
                <VBox spacing="5">
                    <Label text="Contraseña:" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="txtPasswordLogin" promptText="Tu contraseña"
                                  style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
                </VBox>

                <!-- Mensaje de estado login -->
                <Label fx:id="lblMensajeLogin" text=""
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-wrap-text: true; -fx-text-alignment: center;"
                       visible="false" managed="false" maxWidth="350"/>

                <!-- Botón login -->
                <Button fx:id="btnLogin" text="Iniciar Sesión"
                        style="-fx-font-weight: bold; -fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 5px; -fx-cursor: hand; -fx-font-size: 15px; -fx-pref-width: 300px;"/>

                <ProgressIndicator fx:id="progressLogin" visible="false" managed="false"
                                   style="-fx-pref-width: 30px; -fx-pref-height: 30px;"/>

                <Separator/>

                <!-- Cambiar contraseña -->
                <VBox alignment="CENTER" spacing="4">
                    <Label text="¿Olvidaste tu contraseña o tu cuenta está bloqueada?"
                           style="-fx-font-size: 12px; -fx-text-fill: #95a5a6;"/>
                    <Hyperlink fx:id="linkCambiarPassword" text="🔓 Cambiar contraseña"
                               style="-fx-text-fill: #e67e22; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent;"/>
                </VBox>

            </VBox>
        </Tab>

        <!-- ═══════════════════════ TAB REGISTRO ═══════════════════════ -->
        <Tab text="📝  Crear Cuenta" fx:id="tabRegistro">
            <VBox alignment="CENTER" spacing="15" style="-fx-padding: 25px 30px 20px 30px;">

                <Label text="Crear Cuenta" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Label text="Únete para poder realizar compras." style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>

                <VBox spacing="5">
                    <Label text="Nombre Completo:" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtNombre" promptText="Ej. Juan Pérez"
                               style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Correo Electrónico:" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEmail" promptText="ejemplo@correo.com"
                               style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
                    <Label fx:id="lblEmailError" text="Correo inválido"
                           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" visible="false" managed="false"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Contraseña:" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="txtPassword" promptText="Mínimo 6 caracteres"
                                  style="-fx-padding: 8px; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;"/>
                    <Label fx:id="lblPasswordError" text="Mínimo 6 caracteres"
                           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" visible="false" managed="false"/>
                </VBox>

                <Label fx:id="lblMensajeGlobal" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-wrap-text: true; -fx-text-alignment: center;"
                       visible="false" managed="false" maxWidth="350"/>

                <Button fx:id="btnRegistrar" text="Registrarse"
                        style="-fx-font-weight: bold; -fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 5px; -fx-cursor: hand; -fx-font-size: 15px; -fx-pref-width: 300px;"/>

                <ProgressIndicator fx:id="progressIndicator" visible="false" managed="false"
                                   style="-fx-pref-width: 30px; -fx-pref-height: 30px;"/>

            </VBox>
        </Tab>

    </TabPane>

</VBox>
