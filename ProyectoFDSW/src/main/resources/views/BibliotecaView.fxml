<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" style="-fx-font-family: 'Segoe UI', sans-serif; -fx-background-color: #1a252f;">
    
    <!-- Capa Base: Fondo inmersivo con imágenes -->
    <StackPane fx:id="paneFondoBase">
        <ImageView fx:id="imgFondo1" preserveRatio="false" smooth="true" />
        <ImageView fx:id="imgFondo2" preserveRatio="false" smooth="true" opacity="0.0" />
        <!-- Capa oscura para mejorar legibilidad del texto -->
        <Region style="-fx-background-color: rgba(26, 37, 47, 0.6);" />
    </StackPane>

    <!-- Capa Superior: Interfaz -->
    <BorderPane>
        <top>
            <!-- Header completamente transparente para integrarse con el fondo -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 30px 20px 10px 20px; -fx-background-color: transparent;">
                <Label text="MyLib" style="-fx-font-size: 32px; -fx-text-fill: white; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 5, 0, 0, 2);"/>
                <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10px 0 0 0;">
                    <Button fx:id="btnToggleView" text="🛒 Ver Carrito (0)" style="-fx-background-color: rgba(52, 73, 94, 0.7); -fx-text-fill: #f39c12; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10px 25px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-border-color: #f39c12; -fx-border-width: 2px; -fx-border-radius: 30px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 5, 0, 0, 2);"/>
                    <Button fx:id="btnPublicarLibro" text="📚 Publicar Libro" style="-fx-background-color: rgba(230, 126, 34, 0.85); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10px 25px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-border-color: #e67e22; -fx-border-width: 2px; -fx-border-radius: 30px; -fx-effect: dropshadow(three-pass-box, rgba(230,126,34,0.5), 8, 0, 0, 3);"/>
                    <Button fx:id="btnMiBiblioteca" text="📖 Mi Biblioteca" visible="false" managed="false" style="-fx-background-color: rgba(52, 73, 94, 0.7); -fx-text-fill: #9b59b6; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10px 25px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-border-color: #9b59b6; -fx-border-width: 2px; -fx-border-radius: 30px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 5, 0, 0, 2);"/>
                    <Button fx:id="btnMisCompras" text="🧾 Mis Compras" visible="false" managed="false" style="-fx-background-color: rgba(52, 73, 94, 0.7); -fx-text-fill: #2ecc71; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10px 25px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-border-color: #2ecc71; -fx-border-width: 2px; -fx-border-radius: 30px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 5, 0, 0, 2);"/>
                    <Button fx:id="btnLogin" text="🔑 Iniciar Sesión" style="-fx-background-color: rgba(52, 73, 94, 0.7); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10px 25px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-border-color: #3498db; -fx-border-width: 2px; -fx-border-radius: 30px;" />
                    <Button fx:id="btnLogout" text="🚪 Cerrar Sesión" visible="false" managed="false" style="-fx-background-color: rgba(231, 76, 60, 0.7); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10px 25px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-border-color: #c0392b; -fx-border-width: 2px; -fx-border-radius: 30px;" />
                    <Button fx:id="btnAdmin" text="⚙️ Admin" visible="false" managed="false" style="-fx-background-color: linear-gradient(to right, #1a2980, #26d0ce); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10px 25px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-border-color: #26d0ce; -fx-border-width: 2px; -fx-border-radius: 30px; -fx-effect: dropshadow(three-pass-box, rgba(38,208,206,0.5), 8, 0, 0, 3);" />
                </HBox>
            </VBox>
        </top>
        
        <!-- Panel lateral izquierdo: Filtros Avanzados -->
        <left>
            <VBox fx:id="vboxFiltros" spacing="12" visible="false" managed="false" style="-fx-padding: 20px; -fx-background-color: rgba(20, 30, 40, 0.85); -fx-background-radius: 15px; -fx-pref-width: 220px;">
                <BorderPane.margin>
                    <Insets top="20" right="5" bottom="20" left="20" />
                </BorderPane.margin>
                <Label text="Filtros" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                <Separator style="-fx-background-color: #f39c12;"/>
                
                <Label text="Categoria" style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbCategoria" prefWidth="190" promptText="Todas"/>
                
                <Label text="Precio Maximo" style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold;"/>
                <Slider fx:id="sliderPrecioMax" min="0" max="100" value="100"/>
                <Label fx:id="lblPrecioMax" text="Max: sin limite" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;"/>
                
                <Label text="Ordenar por" style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbOrdenamiento" prefWidth="190"/>
            </VBox>
        </left>

        <center>
            <StackPane>
                <!-- Sección de Búsqueda Centrada -->
                <VBox fx:id="vboxBusqueda" spacing="20" alignment="CENTER" style="-fx-padding: 40px;">
                    
                    <VBox alignment="CENTER" spacing="15">
                        <Label fx:id="lblFraseDia" text="Un libro es un sueno que tienes en tus manos." style="-fx-font-size: 32px; -fx-text-fill: white; -fx-font-weight: bold; -fx-text-alignment: center;" wrapText="true"/>
                        <Label text="Descubre mundos increibles en nuestra coleccion digital abierta." style="-fx-font-size: 18px; -fx-text-fill: #ecf0f1; -fx-text-alignment: center;" wrapText="true"/>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 20px 0 20px 0;">
                        <TextField fx:id="txtBusqueda" promptText="Buscar por titulo, autor o ISBN..." style="-fx-pref-width: 600px; -fx-font-size: 18px; -fx-background-radius: 30px; -fx-border-radius: 30px; -fx-padding: 15px 25px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);" />
                    </HBox>
                    
                    <VBox fx:id="vboxResultadosContainer" VBox.vgrow="ALWAYS" spacing="10" visible="false" managed="false" style="-fx-background-color: rgba(255, 255, 255, 0.9); -fx-background-radius: 15px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 20, 0, 0, 10);">
                        <Label text="Resultados de la busqueda" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                        <ListView fx:id="listResultados" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" />
                        <Label fx:id="lblEstado" text="Listo" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                    </VBox>
                </VBox>
                
                <!-- Sección del Carrito -->
                <VBox fx:id="vboxCarrito" spacing="15" style="-fx-padding: 40px; -fx-background-color: rgba(255, 255, 255, 0.95); -fx-background-radius: 15px; -fx-margin: 20px;" visible="false">
                    <Label text="Tu Carrito de Compras" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                    <ListView fx:id="listCarrito" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" />
                    <HBox alignment="CENTER_RIGHT" spacing="15">
                        <Label text="Total a pagar:" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalCarrito" text="\$0.00" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="btnContinuarProceso" text="Continuar con el proceso" style="-fx-font-weight: bold; -fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 18px; -fx-padding: 12px 30px; -fx-background-radius: 30px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);"/>
                    </HBox>
                </VBox>
                
                <!-- Overlay para cargar otras vistas como Login, Checkout, etc. -->
                <StackPane fx:id="overlayPlaceholder" visible="false" managed="false" style="-fx-background-color: rgba(26, 37, 47, 0.95); -fx-padding: 20px;">
                </StackPane>
            </StackPane>
        </center>
        
        <right>
            <VBox spacing="15" style="-fx-padding: 20px; -fx-pref-width: 350px;">
                <BorderPane.margin>
                    <Insets top="20" right="20" bottom="20" left="10" />
                </BorderPane.margin>
                
                <!-- Tendencias -->
                <VBox spacing="10" style="-fx-background-color: rgba(20, 30, 40, 0.5); -fx-background-radius: 15px; -fx-padding: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 5);">
                    <Label text="Tendencias" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                    <Label text="Los libros mas consultados" style="-fx-font-size: 12px; -fx-text-fill: #ecf0f1;"/>
                    <ListView fx:id="listTendencias" prefHeight="200" style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;" />
                </VBox>

                <!-- Recomendaciones -->
                <VBox fx:id="vboxRecomendaciones" spacing="10" style="-fx-background-color: rgba(46, 204, 113, 0.15); -fx-background-radius: 15px; -fx-padding: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 5); -fx-border-color: rgba(46, 204, 113, 0.4); -fx-border-radius: 15px;">
                    <Label text="Recomendados para ti" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
                    <Label text="Basado en tus gustos" style="-fx-font-size: 12px; -fx-text-fill: #ecf0f1;"/>
                    <ListView fx:id="listRecomendaciones" prefHeight="200" style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;" />
                </VBox>
            </VBox>
        </right>
    </BorderPane>
</StackPane>
