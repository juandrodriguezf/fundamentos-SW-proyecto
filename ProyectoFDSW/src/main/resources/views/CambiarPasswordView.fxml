<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           style="-fx-background-color: linear-gradient(to bottom right, #0f0c29, #302b63, #24243e);">

    <VBox alignment="CENTER" spacing="0"
          style="-fx-background-color: rgba(255,255,255,0.07);
                 -fx-background-radius: 20px;
                 -fx-border-color: rgba(255,255,255,0.15);
                 -fx-border-radius: 20px;
                 -fx-border-width: 1px;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 40, 0, 0, 10);"
          maxWidth="400" maxHeight="520">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8"
              style="-fx-background-color: linear-gradient(to right, #f59e0b, #ef4444);
                     -fx-background-radius: 20px 20px 0 0;
                     -fx-padding: 30px 30px 22px 30px;">
            <Label text="🔓" style="-fx-font-size: 36px;"/>
            <Label text="Cambiar Contraseña"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI';"/>
            <Label text="Ingresa tu email y tu nueva contraseña"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-family: 'Segoe UI';"/>
        </VBox>

        <!-- Formulario -->
        <VBox spacing="18" style="-fx-padding: 30px 35px 30px 35px;">

            <!-- Email -->
            <VBox spacing="6">
                <Label text="Correo Electrónico"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-family: 'Segoe UI';"/>
                <TextField fx:id="txtEmailCambio"
                           promptText="ejemplo@correo.com"
                           style="-fx-background-color: rgba(255,255,255,0.1);
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: rgba(255,255,255,0.4);
                                  -fx-padding: 12px 15px;
                                  -fx-font-size: 14px;
                                  -fx-background-radius: 10px;
                                  -fx-border-color: rgba(255,255,255,0.2);
                                  -fx-border-radius: 10px;
                                  -fx-font-family: 'Segoe UI';"/>
            </VBox>

            <!-- Nueva contraseña -->
            <VBox spacing="6">
                <Label text="Nueva Contraseña"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-family: 'Segoe UI';"/>
                <PasswordField fx:id="txtNuevoPassword"
                               promptText="Mínimo 6 caracteres"
                               style="-fx-background-color: rgba(255,255,255,0.1);
                                      -fx-text-fill: white;
                                      -fx-prompt-text-fill: rgba(255,255,255,0.4);
                                      -fx-padding: 12px 15px;
                                      -fx-font-size: 14px;
                                      -fx-background-radius: 10px;
                                      -fx-border-color: rgba(255,255,255,0.2);
                                      -fx-border-radius: 10px;
                                      -fx-font-family: 'Segoe UI';"/>
                <Label fx:id="lblPasswordError" text="Mínimo 6 caracteres"
                       style="-fx-text-fill: #fca5a5; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';"
                       visible="false" managed="false"/>
            </VBox>

            <!-- Mensaje de estado -->
            <Label fx:id="lblMensajeCambio" text=""
                   style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI'; -fx-wrap-text: true; -fx-text-alignment: center;"
                   visible="false" managed="false" maxWidth="330"/>

            <!-- Botón cambiar -->
            <Button fx:id="btnCambiarPassword" text="Cambiar Contraseña"
                    style="-fx-background-color: linear-gradient(to right, #f59e0b, #ef4444);
                           -fx-text-fill: white;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-padding: 13px 20px;
                           -fx-background-radius: 10px;
                           -fx-cursor: hand;
                           -fx-font-family: 'Segoe UI';"
                    maxWidth="Infinity"/>

            <ProgressIndicator fx:id="progressIndicatorCambio" visible="false" managed="false"
                               style="-fx-pref-width: 35px; -fx-pref-height: 35px;"/>

            <!-- Volver -->
            <Button fx:id="btnVolver" text="← Volver al Login"
                    style="-fx-background-color: rgba(255,255,255,0.1);
                           -fx-text-fill: rgba(255,255,255,0.7);
                           -fx-font-size: 13px;
                           -fx-padding: 10px 20px;
                           -fx-background-radius: 10px;
                           -fx-cursor: hand;
                           -fx-font-family: 'Segoe UI';
                           -fx-border-color: rgba(255,255,255,0.2);
                           -fx-border-radius: 10px;"
                    maxWidth="Infinity"/>
        </VBox>
    </VBox>
</StackPane>
