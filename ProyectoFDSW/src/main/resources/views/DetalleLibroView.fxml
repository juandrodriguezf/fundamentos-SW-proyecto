<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      spacing="20" alignment="TOP_CENTER" style="-fx-background-color: #ffffff; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
    
    <HBox spacing="30" alignment="CENTER_LEFT" prefWidth="700">
        <!-- Portada con sombra -->
        <VBox style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 15, 0, 0, 5);">
            <ImageView fx:id="imgPortada" fitWidth="200" fitHeight="300" preserveRatio="true"/>
        </VBox>
        
        <VBox spacing="12" HBox.hgrow="ALWAYS">
            <Label fx:id="lblCategoria" text="Categoría" style="-fx-text-fill: #3498db; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label fx:id="lblTitulo" wrapText="true" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="lblAutor" style="-fx-font-size: 18px; -fx-text-fill: #7f8c8d;"/>
            
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Label fx:id="lblCalificacion" text="⭐⭐⭐⭐⭐" style="-fx-font-size: 18px; -fx-text-fill: #f1c40f;"/>
                <Label fx:id="lblReviewCount" text="(0 reseñas)" style="-fx-text-fill: #95a5a6;"/>
            </HBox>
            
            <HBox fx:id="tagsContainer" spacing="8" alignment="CENTER_LEFT"/>
            
            <Region VBox.vgrow="ALWAYS" minHeight="15"/>
            
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label fx:id="lblPrecio" style="-fx-font-size: 26px; -fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
                <Label fx:id="lblStock" text="En Stock" style="-fx-background-color: #e8f8f5; -fx-text-fill: #2ecc71; -fx-padding: 5 15; -fx-background-radius: 15; -fx-font-weight: bold;"/>
            </HBox>
            
            <Button fx:id="btnComprar" text="🛒 Añadir al Carrito" style="-fx-background-color: linear-gradient(to right, #3498db, #2980b9); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 12 30; -fx-background-radius: 25; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(52,152,219,0.5), 10, 0, 0, 4);"/>
        </VBox>
    </HBox>

    <Separator style="-fx-padding: 10 0;"/>
    
    <!-- Sección de reseñas -->
    <VBox spacing="15" prefWidth="700">
        <Label text="Reseñas de Clientes" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        <ListView fx:id="listReviews" prefHeight="250" style="-fx-background-color: transparent; -fx-border-color: #ecf0f1; -fx-border-radius: 8;"/>
    </VBox>
    
    <Separator style="-fx-padding: 10 0;"/>

    <VBox spacing="15" prefWidth="700" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #e9ecef; -fx-border-radius: 10;">
        <Label text="Escribir una Reseña" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Tu Calificación:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbCalificacion" style="-fx-background-radius: 5;"/>
        </HBox>
        <TextArea fx:id="txtComentario" promptText="Cuéntanos qué te pareció el libro (ej. trama, personajes, estilo...)" prefHeight="80" wrapText="true" style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
        <HBox alignment="CENTER_RIGHT">
            <Button fx:id="btnEnviarReview" text="⭐ Publicar Reseña" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(243,156,18,0.4), 8, 0, 0, 3);"/>
        </HBox>
    </VBox>
</VBox>
