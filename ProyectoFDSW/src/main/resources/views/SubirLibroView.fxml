<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #ecf0f1; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label text="Subir Nuevo Libro" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <VBox spacing="5.0">
         <children>
            <Label text="Título:" />
            <TextField fx:id="txtTitulo" promptText="Ingrese el título del libro" />
         </children>
      </VBox>
      <VBox spacing="5.0">
         <children>
            <Label text="Autor:" />
            <TextField fx:id="txtAutor" promptText="Ingrese el autor" />
         </children>
      </VBox>
      <VBox spacing="5.0">
         <children>
            <Label text="Categoría:" />
            <TextField fx:id="txtCategoria" promptText="Ej: Ingeniería de Software" />
         </children>
      </VBox>
      <VBox spacing="5.0">
         <children>
            <Label text="Precio:" />
            <TextField fx:id="txtPrecio" promptText="0.00" />
         </children>
      </VBox>
      <VBox spacing="5.0">
         <children>
            <Label text="Archivo (PDF o EPUB):" />
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="txtRutaArchivo" editable="false" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnSeleccionarArchivo" mnemonicParsing="false" text="Examinar" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Button fx:id="btnSubir" defaultButton="true" mnemonicParsing="false" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Subir Libro">
         <VBox.margin>
            <Insets top="20.0" />
         </VBox.margin>
      </Button>
   </children>
</VBox>
